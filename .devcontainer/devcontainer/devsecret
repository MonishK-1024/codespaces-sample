#!/bin/bash
# devsecret — read-only CLI for accessing developer secrets.
#
# Secrets are stored as individual files in /run/devuser-secrets/.
# The directory is owned by root:devsecrets (mode 750) and bind-mounted
# read-only from the Codespace VM. Copilot and Claude Code cannot reach it
# because it is outside /workspace (their configured allowedDirectories).
#
# Usage:
#   devsecret list              List available secret names
#   devsecret show <NAME>       Print the value of a secret to stdout
#   devsecret export            Print 'export KEY=VALUE' lines (use with source)
#
# Examples:
#   devsecret show DB_PASSWORD
#   source <(devsecret export)

set -euo pipefail

SECRETS_DIR="/run/devuser-secrets"

USAGE=$(cat <<'EOF'
devsecret — read-only access to developer secrets

Usage:
  devsecret list              List available secret names
  devsecret show <NAME>       Print value to stdout
  devsecret export            Print 'export KEY=VALUE' for all secrets
  devsecret --help            Show this help

Examples:
  devsecret show DB_PASSWORD
  source <(devsecret export)
EOF
)

cmd="${1:-}"

_check_dir() {
    if [ ! -d "$SECRETS_DIR" ]; then
        echo "Error: secrets directory not found at $SECRETS_DIR" >&2
        echo "The secrets volume may not have been populated." >&2
        exit 1
    fi
}

case "$cmd" in
    list)
        _check_dir
        files=("$SECRETS_DIR"/*)
        if [ "${#files[@]}" -eq 0 ] || [ ! -f "${files[0]}" ]; then
            echo "(no secrets available)"
        else
            for f in "$SECRETS_DIR"/*; do
                [ -f "$f" ] && basename "$f"
            done
        fi
        ;;

    show)
        name="${2:-}"
        if [ -z "$name" ]; then
            echo "Error: provide a secret name." >&2
            echo "$USAGE" >&2
            exit 1
        fi
        _check_dir
        path="$SECRETS_DIR/$name"
        if [ ! -f "$path" ]; then
            echo "Error: secret '$name' not found." >&2
            echo "Run 'devsecret list' to see available secrets." >&2
            exit 1
        fi
        cat "$path"
        ;;

    export)
        _check_dir
        found=0
        for f in "$SECRETS_DIR"/*; do
            [ -f "$f" ] || continue
            name="$(basename "$f")"
            # Only export names that are valid shell variable identifiers
            if [[ "$name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
                value="$(cat "$f")"
                printf 'export %s=%q\n' "$name" "$value"
                found=$((found + 1))
            fi
        done
        if [ "$found" -eq 0 ]; then
            echo "# (no secrets available)" >&2
        fi
        ;;

    --help | -h | help | "")
        echo "$USAGE"
        ;;

    *)
        echo "Error: unknown command '$cmd'" >&2
        echo "$USAGE" >&2
        exit 1
        ;;
esac
